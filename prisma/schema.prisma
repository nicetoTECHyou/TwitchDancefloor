generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Effect {
  id          String  @id @default(cuid())
  name        String  @unique
  label       String
  category    String  @default("light")
  enabled     Boolean @default(false)
  intensity   Float   @default(0.7)
  speed       Float   @default(1.0)
  color       String  @default("#ffffff")
  position    String  @default("auto")
  sortOrder   Int     @default(0)
  commands    ChatCommand[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatCommand {
  id          String  @id @default(cuid())
  command     String  @unique
  effectId    String
  effect      Effect  @relation(fields: [effectId], references: [id], onDelete: Cascade)
  action      String  @default("toggle")
  description String  @default("")
  cooldown    Int     @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChannelSetting {
  id          String  @id @default(cuid())
  channelName String  @unique
  platform    String  @default("twitch")
  connected   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalSetting {
  id                String  @id @default(cuid())
  key               String  @unique
  value             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
